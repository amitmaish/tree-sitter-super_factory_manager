    "license": "MIT",
    "description": "A Minecraft mod that adds a domain-specific language for logistics automation.",
    "authors": [
      {
        "name": "amit maish",
        "url": ""
      }
    ],
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-super_factory_manager",
      "funding": ""
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "java": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": true
  }
