{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "super_factory_manager",
      "camelcase": "SuperFactoryManager",
      "title": "SuperFactoryManager",
      "scope": "source.super_factory_manager",
      "file-types": [
